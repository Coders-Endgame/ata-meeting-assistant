# Supabase Cloud credentials (Dashboard > Settings > API)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# For backend server and bot
SUPABASE_URL=https://<your-project-ref>.supabase.co

# For summarizer service (Ollama)
OLLAMA_HOST=http://localhost:11434

# For Whisper transcription (local model)
WHISPER_MODEL=base

# For offline summarization 
REMOTE_LLM_PROVIDER=groq # only groq supported currently
REMOTE_LLM_API_KEY=your_llm_api_key

# groq: llama-3.1-8b-instant model is used for testing, llama-3.3-70b-versatile can be used for better performance
REMOTE_LLM_MODEL=llama-3.1-8b-instant