{
  "name": "ata-meeting-assistant",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:stack:check": "node tests/helpers/preflight.mjs",
    "test:e2e:browser-check": "PLAYWRIGHT_BROWSERS_PATH=/tmp/ms-playwright node tests/helpers/playwright-preflight.mjs",
    "test:integration": "node tests/helpers/preflight.mjs integration && node --test --test-concurrency=1 tests/integration/api.test.mjs",
    "test:load": "node tests/helpers/preflight.mjs integration && node --test --test-concurrency=1 tests/integration/load.test.mjs",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=/tmp/ms-playwright node tests/helpers/preflight.mjs e2e && npm run test:e2e:browser-check && PLAYWRIGHT_BROWSERS_PATH=/tmp/ms-playwright playwright test",
    "test:python": "python3 -m pytest services/summarizer/tests",
    "test": "npm run test:integration && npm run test:e2e && npm run test:python"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@mui/x-date-pickers": "^8.26.0",
    "@supabase/supabase-js": "^2.93.3",
    "dayjs": "^1.11.19",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
